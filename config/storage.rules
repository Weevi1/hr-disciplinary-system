rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read warning audio files
    match /warnings/{organizationId}/{warningId}/audio/{audioFile} {
      // Read access - any authenticated user can read (match catch-all behavior)
      allow read: if request.auth != null;

      // Write access - with file type and size validation
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && audioFile.matches('.*\\.(webm|mp3|wav|m4a)$')
        && request.resource.size < 2 * 1024 * 1024; // 2MB limit
    }
    
    // Public read access for temporary PDF downloads (1-hour expiry)
    //
    // Access control is enforced at the URL layer, not by Storage rules:
    // Cloud Functions mint signed URLs with a 1-hour expiry whenever a QR code
    // PDF needs to be served to an unauthenticated recipient. Without the signed
    // URL, the path is unguessable (orgId + filename UUID). See
    // functions/src/temporaryDownload.ts for the URL-minting logic. The `if true`
    // is intentional: this bucket is the public delivery surface, gated by URL
    // possession and time-to-live.
    match /temp-downloads/{organizationId}/{filename} {
      allow read: if true; // Public read access for QR code downloads
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && filename.matches('.*\\.pdf$')
        && request.resource.size < 10 * 1024 * 1024; // 10MB limit for PDFs
    }
    
    // Allow authenticated users to upload warning evidence during wizard
    match /warnings/{organizationId}/{warningId}/evidence/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && file.matches('.*\\.(jpg|jpeg|png|webp|heic|pdf|doc|docx)$')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Generated warning PDFs (uploaded by UnifiedWarningWizard at end of flow,
    // read by PDFViewerModal in the app, also read by Cloud Functions via
    // Admin SDK for email/response delivery)
    match /warnings/{organizationId}/{warningId}/pdfs/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && file.matches('.*\\.pdf$')
        && request.resource.size < 10 * 1024 * 1024; // 10MB PDF limit
    }

    // Allow authenticated users to upload appeal evidence
    match /appeals/{organizationId}/{warningId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && file.matches('.*\\.(jpg|jpeg|png|webp|heic|pdf|doc|docx)$')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Public read for employee response evidence (uploaded via Cloud Function)
    //
    // Access control is enforced at the URL layer, not by Storage rules:
    // employee response links carry a token (functions/src/employeeResponse.ts:365
    // mints signed URLs with expiry). The path is unguessable without the token.
    // Writes are admin-SDK only (Cloud Function handles upload server-side).
    // The `if true` read is intentional: this bucket is the response-link delivery
    // surface, gated by token possession and signed-URL TTL.
    match /response-evidence/{organizationId}/{warningId}/{file} {
      allow read: if true; // Public - accessed via response links
      // Write handled by Cloud Function admin SDK (no client writes)
    }

    // Organization-scoped storage (logos, signatures, audio analytics, etc.)
    //
    // Read: org members, super-users, or resellers. Resellers are trusted across
    //       all orgs at the storage layer; tighter scoping by resellerId would
    //       require a firestore.get() which is expensive — Phase 2+ work.
    // Write: same set, but email_verified required (matches other write rules).
    //
    // NEW abbreviated claim format only. LEGACY (`organizationId`, `role`)
    // fallback removed 2026-05-10 after Phase 1.5 bulk claim refresh.
    match /organizations/{organizationId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.org == organizationId ||
        request.auth.token.r == 'super-user' ||
        request.auth.token.r == 'reseller'
      );
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && (
          request.auth.token.org == organizationId ||
          request.auth.token.r == 'super-user' ||
          request.auth.token.r == 'reseller'
        );
    }

    // Deny by default - any path not explicitly matched above is rejected.
    // This replaces the previous catch-all `allow read, write: if request.auth != null`
    // which was wide open across all unmatched paths. New storage paths must add
    // an explicit match block above this rule.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}