rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read warning audio files
    match /warnings/{organizationId}/{warningId}/audio/{audioFile} {
      // Read access - any authenticated user can read (match catch-all behavior)
      allow read: if request.auth != null;

      // Write access - with file type and size validation
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && audioFile.matches('.*\\.(webm|mp3|wav|m4a)$')
        && request.resource.size < 2 * 1024 * 1024; // 2MB limit
    }
    
    // Public read access for temporary PDF downloads (1-hour expiry)
    match /temp-downloads/{organizationId}/{filename} {
      allow read: if true; // Public read access for QR code downloads
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && filename.matches('.*\\.pdf$')
        && request.resource.size < 10 * 1024 * 1024; // 10MB limit for PDFs
    }
    
    // Allow authenticated users to upload warning evidence during wizard
    match /warnings/{organizationId}/{warningId}/evidence/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && file.matches('.*\\.(jpg|jpeg|png|webp|heic|pdf|doc|docx)$')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Allow authenticated users to upload appeal evidence
    match /appeals/{organizationId}/{warningId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && file.matches('.*\\.(jpg|jpeg|png|webp|heic|pdf|doc|docx)$')
        && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Public read for employee response evidence (uploaded via Cloud Function)
    match /response-evidence/{organizationId}/{warningId}/{file} {
      allow read: if true; // Public - accessed via response links
      // Write handled by Cloud Function admin SDK (no client writes)
    }

    // Allow authenticated users for other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}